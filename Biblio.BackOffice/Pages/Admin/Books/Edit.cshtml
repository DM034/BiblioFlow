@page "{id:int}"
@model Biblio.BackOffice.Pages.Admin.Books.EditModel
@{
  ViewData["Title"] = "Edit Book";
}

<div class="bo-page-header">
  <div>
    <h2 class="mb-1">Edit book</h2>
    <div class="small text-muted">Update metadata for <strong>@Model.Book.Title</strong>.</div>
  </div>
</div>

<div class="card border-0">
  <div class="card-body">
    @if (!ViewData.ModelState.IsValid)
    {
      <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <form method="post" class="row g-3">
      <input asp-for="Book.Id" type="hidden" />

      <div class="col-md-6">
        <label asp-for="Book.Title" class="form-label">Title</label>
        <input asp-for="Book.Title" class="form-control" required />
      </div>

      <div class="col-md-6">
        <label asp-for="Book.Author" class="form-label">Author</label>
        <input asp-for="Book.Author" class="form-control" required />
      </div>

      <div class="col-md-6">
        <label asp-for="Book.Category" class="form-label">Category</label>
        <input asp-for="Book.Category" class="form-control" />
      </div>

      <div class="col-md-3">
        <label asp-for="Book.Year" class="form-label">Year</label>
        <input asp-for="Book.Year" class="form-control" type="number" />
      </div>

      <div class="col-12">
        <label asp-for="Book.Summary" class="form-label">Summary</label>
        <textarea asp-for="Book.Summary" class="form-control" rows="4"></textarea>
      </div>

      <div class="col-12 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Save</button>
        <a class="btn btn-ghost-light" href="/Admin/Books">Back</a>
      </div>
    </form>

    <div class="mt-3 small text-muted">
      PDF:
      @if (string.IsNullOrWhiteSpace(Model.Book.PdfPath))
      {
        <span>none</span>
      }
      else
      {
        <code>@Model.Book.PdfPath</code>
      }
    </div>
  </div>
</div>
