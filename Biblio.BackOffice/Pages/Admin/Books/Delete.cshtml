@page
@model Biblio.BackOffice.Pages.Admin.Books.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<div class="bo-page-header">
  <div>
    <h2 class="mb-1">Delete book</h2>
    <div class="small text-muted">This action is permanent and cannot be undone.</div>
  </div>
</div>

<div class="card border-0">
  <div class="card-body">
    <div class="alert alert-danger mb-3">Are you sure you want to delete this book?</div>

    <dl class="row mb-0">
      <dt class="col-sm-3 col-lg-2 text-muted">Title</dt>
      <dd class="col-sm-9 col-lg-10">@Html.DisplayFor(model => model.Book.Title)</dd>

      <dt class="col-sm-3 col-lg-2 text-muted">Author</dt>
      <dd class="col-sm-9 col-lg-10">@Html.DisplayFor(model => model.Book.Author)</dd>

      <dt class="col-sm-3 col-lg-2 text-muted">Category</dt>
      <dd class="col-sm-9 col-lg-10">@Html.DisplayFor(model => model.Book.Category)</dd>

      <dt class="col-sm-3 col-lg-2 text-muted">Year</dt>
      <dd class="col-sm-9 col-lg-10">@Html.DisplayFor(model => model.Book.Year)</dd>

      <dt class="col-sm-3 col-lg-2 text-muted">Summary</dt>
      <dd class="col-sm-9 col-lg-10">@Html.DisplayFor(model => model.Book.Summary)</dd>

      <dt class="col-sm-3 col-lg-2 text-muted">PDF path</dt>
      <dd class="col-sm-9 col-lg-10">@Html.DisplayFor(model => model.Book.PdfPath)</dd>
    </dl>

    <form method="post" class="d-flex gap-2 mt-3">
      <input type="hidden" asp-for="Book.Id" />
      <button type="submit" class="btn btn-danger">Delete</button>
      <a class="btn btn-ghost-light" asp-page="./Index">Back to list</a>
    </form>
  </div>
</div>
