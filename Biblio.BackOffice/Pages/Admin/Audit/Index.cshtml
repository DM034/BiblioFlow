@page
@model Biblio.BackOffice.Pages.Admin.Audit.IndexModel
@{
  ViewData["Title"] = "Audit";
}

<div class="bo-page-header">
  <div>
    <h2 class="mb-1">Audit trail</h2>
    <div class="small text-muted">Recent admin actions across BackOffice.</div>
  </div>
</div>

<div class="card border-0">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>At (UTC)</th>
          <th>Admin</th>
          <th>Action</th>
          <th>Entity</th>
          <th>EntityId</th>
          <th>Details</th>
          <th>IP</th>
        </tr>
      </thead>
      <tbody>
      @if (Model.Rows.Count == 0)
      {
        <tr>
          <td colspan="7">
            <div class="bo-empty my-2">No audit events yet.</div>
          </td>
        </tr>
      }

      @foreach (var row in Model.Rows)
      {
        <tr>
          <td>@row.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
          <td>@row.AdminEmail</td>
          <td><span class="badge text-bg-dark">@row.Action</span></td>
          <td>@row.EntityType</td>
          <td>@(string.IsNullOrWhiteSpace(row.EntityId) ? "—" : row.EntityId)</td>
          <td class="small text-muted">@row.Details</td>
          <td>@(string.IsNullOrWhiteSpace(row.IpAddress) ? "—" : row.IpAddress)</td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
