@using Microsoft.AspNetCore.Http
<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>@ViewData["Title"] - BiblioFlow</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="~/css/front.css" asp-append-version="true" />
</head>
<body>
@{
  var email = Context.Session.GetString("email");
  var isAuth = !string.IsNullOrWhiteSpace(email);
  var path = Context.Request.Path.Value ?? "";
  bool IsPath(string prefix) => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
  var isBooks = path == "/" || IsPath("/Books");
  var isLoans = IsPath("/Books/MyLoans") || IsPath("/Loans");
  var isLogin = IsPath("/Account/Login");
}

<header class="fo-topbar">
  <div class="container py-3 d-flex align-items-center justify-content-between gap-3">
    <a class="fo-brand" href="/Books">
      <div class="fo-logo">BF</div>
      <div>
        <div class="fw-semibold lh-1">BiblioFlow</div>
        <div class="small text-white-50 lh-1">FrontOffice</div>
      </div>
    </a>

    <div class="fo-nav">
      <a class="btn btn-ghost btn-sm @(isBooks ? "active" : "")" href="/Books">Catalogue</a>

      @if (isAuth)
      {
        <a class="btn btn-ghost btn-sm @(isLoans ? "active" : "")" href="/Books/MyLoans">My Loans</a>
        <span class="fo-pill">Logged as: <strong class="fo-email text-truncate">@email</strong></span>
        <form method="post" action="/Account/Logout" class="d-inline">
          <button type="submit" class="btn btn-ghost btn-sm">Logout</button>
        </form>
      }
      else
      {
        <a class="btn btn-primary btn-sm @(isLogin ? "active" : "")" href="/Account/Login">Login</a>
      }
    </div>
  </div>
</header>

<main class="container fo-main">
  @if (TempData["Msg"] is string msg && !string.IsNullOrWhiteSpace(msg))
  {
    <div class="alert alert-info">@msg</div>
  }
  @if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
  {
    <div class="alert alert-danger">@err</div>
  }

  @RenderBody()

  <div class="fo-footer mt-4">
    © @DateTime.UtcNow.Year BiblioFlow
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
