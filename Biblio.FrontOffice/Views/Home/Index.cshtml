@{
    ViewData["Title"] = "Home";
}

<div class="fo-hero mb-3">
  <h1>Welcome to BiblioFlow</h1>
  <p>Your digital library with borrowing rules and concurrent seats.</p>
</div>

<div class="row align-items-stretch g-4">
  <div class="col-lg-7">
    <div class="fo-card fo-card-body p-4 p-lg-5 h-100">
      <h2 class="display-6 fw-semibold mb-3">Your digital library, with real borrowing rules.</h2>
      <p class="muted mb-4">
        Browse books, borrow with seat licensing, read PDFs during the loan period, and manage returns.
      </p>
      <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-controller="Books" asp-action="Index">Open Catalogue</a>
        <a class="btn btn-ghost" asp-controller="Loans" asp-action="Index">My Loans</a>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="fo-card fo-card-body p-4 h-100">
      <h5 class="fw-semibold mb-3">Quick checklist</h5>
      <ul class="mb-0 muted">
        <li>Create books in BackOffice</li>
        <li>Upload PDF for a book (BackOffice)</li>
        <li>Borrow from FrontOffice</li>
        <li>Read during loan period</li>
        <li>Return to free a seat</li>
      </ul>
    </div>
  </div>
</div>
